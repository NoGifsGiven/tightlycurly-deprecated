@page "/answerbank/{questionName?}"
@model TightlyCurly.Com.Web.Pages.AnswerBankModel

<h2>Answer Bank</h2>

<section class="answer-bank-search">
    <form method="get" asp-page="/AnswerBank">
        <label for="search">Search questions:</label>
        <input type="text" id="search" name="search" value="@Model.SearchText" />
        <button type="submit">Search</button>
    </form>
</section>

<section class="answer-bank-topics">
    <form method="get" asp-page="/AnswerBank">
        <label for="masterCategoryId">Topics:</label>
        <select id="masterCategoryId" name="masterCategoryId" onchange="this.form.submit()">
            <option value="">Please select a topic.</option>
            @foreach (var category in Model.MasterCategories)
            {
                if (Model.SelectedMasterCategoryId == category.QuestionCategoryId)
                {
                    <option value="@category.QuestionCategoryId" selected>@category.Category</option>
                }
                else
                {
                    <option value="@category.QuestionCategoryId">@category.Category</option>
                }
            }
        </select>

        @if (Model.SelectedMasterCategoryId > 0)
        {
            <label for="subcategoryId">Subtopics:</label>
            <select id="subcategoryId" name="subcategoryId">
                <option value="0">@Resources.TightlyCurly.Com.Web.selectSubTopicText</option>
                @foreach (var subcategory in Model.Subcategories)
                {
                    <option value="@subcategory.QuestionCategoryId">@subcategory.Category</option>
                }
            </select>
            <input type="hidden" name="masterCategoryId" value="@Model.SelectedMasterCategoryId" />
            <button type="submit">View Questions</button>
        }
    </form>
</section>

@if (Model.SelectedQuestions.Any())
{
    <section class="answer-bank-results">
        @foreach (var question in Model.SelectedQuestions)
        {
            <article class="question">
                <h3>@Html.Raw(question.Value)</h3>
                <div class="answer">@Html.Raw(question.Answer)</div>
            </article>
        }
    </section>
}

<section class="answer-bank-all">
    <h3>All Questions</h3>
    <ul>
        @foreach (var question in Model.AllQuestions)
        {
            <li><a asp-page="/AnswerBank" asp-route-questionId="@question.QuestionId">@question.Value</a></li>
        }
    </ul>
</section>
