{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "TightlyCurly": "",
    "ALLIGOSHEE_HAIR_ADMINConnectionString": "",
    "ContentService": "/api/questions",
    "ProductService": "/api/ingredients",
    "AutoCompleteService": "/api/autocomplete"
  },
  "AppSettings": {
    "enableAnalytics": "false",
    "CacheEnabled": "true",
    "DefaultCacheExpiration": "20",
    "defaultPage": "welcome",
    "baseSiteUrl": "http://www.tightlycurly.com/",
    "ingredientsUrlPrefix": "ingredients/",
    "ingredientsUrlPriority": "0.5",
    "ingredientsUrlChangeFrequency": "Monthly",
    "questionsUrlPrefix": "answers/",
    "questionsUrlPriority": "0.5",
    "questionsUrlChangeFrequency": "Monthly",
    "IngredientsNameListServiceMethod": "GetIngredientsNameList",
    "QuestionListServiceMethod": "GetQuestionsList"
  },
  "Ingredients": {
    "AvoidStyle": "avoid",
    "CautionStyle": "caution",
    "AcceptableStyle": "acceptable",
    "GoodStyle": "good",
    "LinkUrl": "/ingredients",
    "AutoCompleteEnabled": true,
    "SearchCategories": [
